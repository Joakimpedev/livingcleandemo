ht=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z\"><\u002Fpath><polyline points=\"14 2 14 8 20 8\"><\u002Fpolyline><line x1=\"9\" y1=\"13\" x2=\"15\" y2=\"13\"><\u002Fline><line x1=\"9\" y1=\"17\" x2=\"15\" y2=\"17\"><\u002Fline><\u002Fsvg>\n            <div class=\"row-text\">\n              <div class=\"row-label\">Perm<\u002Fdiv>\n              <div class=\"row-sub\">HMS, rapporter, kontrakt<\u002Fdiv>\n            <\u002Fdiv>\n            <svg class=\"row-arrow\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M9 18l6-6-6-6\"><\u002Fpath><\u002Fsvg>\n          <\u002Fdiv>\n        <\u002Fdiv>\n\n        <h2 class=\"section-title\">Oppdateringer<\u002Fh2>\n\n        <article class=\"update-card\">\n          <div class=\"update-head\">\n            <div class=\"update-brand\">\n              <div class=\"update-logo\">LC<\u002Fdiv>\n              <div>\n                <div class=\"update-author\">Living Clean<\u002Fdiv>\n                <div class=\"update-time\">2 timer siden<\u002Fdiv>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n          <div class=\"update-body\">Vi har byttet til Svanemerket allroundsåpe på alle lokasjoner. Bedre for inneklima, samme pris for dere.<\u002Fdiv>\n          <div class=\"update-actions\">\n            <button class=\"like-btn\" onclick=\"toggleLike(this)\" aria-label=\"Lik\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\"><\u002Fpath><\u002Fsvg>\n              <span class=\"like-count\">24<\u002Fspan>\n            <\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Farticle>\n\n        <article class=\"update-card\">\n          <div class=\"update-head\">\n            <div class=\"update-brand\">\n              <div class=\"update-logo\">LC<\u002Fdiv>\n              <div>\n                <div class=\"update-author\">Living Clean<\u002Fdiv>\n                <div class=\"update-time\">I går<\u002Fdiv>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n          <div class=\"update-body\">Påskeuken nærmer seg — skjærtorsdag og langfredag har vi minimumsbemanning. Daglig renhold er normalt fra 2. påskedag.<\u002Fdiv>\n          <div class=\"update-actions\">\n            <button class=\"like-btn\" onclick=\"toggleLike(this)\" aria-label=\"Lik\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\"><\u002Fpath><\u002Fsvg>\n              <span class=\"like-count\">18<\u002Fspan>\n            <\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Farticle>\n\n        <article class=\"update-card\">\n          <div class=\"update-head\">\n            <div class=\"update-brand\">\n              <div class=\"update-logo\">LC<\u002Fdiv>\n              <div>\n                <div class=\"update-author\">Living Clean<\u002Fdiv>\n                <div class=\"update-time\">3 dager siden<\u002Fdiv>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n          <div class=\"update-body\">Tips: bruk \"Før og etter\"-galleriet til å se resultatet av periodisk arbeid. Fint å vise sjefen eller huseier hva som faktisk er gjort.<\u002Fdiv>\n          <div class=\"update-actions\">\n            <button class=\"like-btn\" onclick=\"toggleLike(this)\" aria-label=\"Lik\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\"><\u002Fpath><\u002Fsvg>\n              <span class=\"like-count\">41<\u002Fspan>\n            <\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Farticle>\n      <\u002Fdiv>\n\n      <!-- NYHETER / FEED SCREEN -->\n      <div class=\"screen\" id=\"screen-news\">\n        <span class=\"eyebrow\">Fra Living Clean til alle kunder<\u002Fspan>\n        <h1 class=\"screen-title\">Nyheter<\u002Fh1>\n\n        <article class=\"news-post pinned\">\n          <div class=\"news-tag\">Festet innlegg<\u002Fdiv>\n          <h3 class=\"news-title\">Påskeuken 2026 — redusert drift<\u002Fh3>\n          <div class=\"news-date\">Publisert 15. april<\u002Fdiv>\n          <p class=\"news-body\">Skjærtorsdag og langfredag har vi minimumsbemanning. Daglig renhold utføres som normalt fra og med 2. påskedag. Ekstraoppdrag kan bestilles som vanlig i appen.<\u002Fp>\n        <\u002Farticle>\n\n        <article class=\"news-post\">\n          <h3 class=\"news-title\">Nytt Svanemerket vaskemiddel i bruk<\u002Fh3>\n          <div class=\"news-date\">11. april<\u002Fdiv>\n          <p class=\"news-body\">Vi har byttet ut allroundsåpen til et Svanemerket alternativ som er bedre for inneklima og allergikere. Ingen endring i pris for dere.<\u002Fp>\n        <\u002Farticle>\n\n        <article class=\"news-post\">\n          <h3 class=\"news-title\">Ny i teamet — velkommen Thomas<\u002Fh3>\n          <div class=\"news-date\">3. april<\u002Fdiv>\n          <p class=\"news-body\">Thomas Eide starter hos oss denne uken og vil dekke vindus- og spesialoppdrag i Bergen sentrum. Du møter ham sikkert snart.<\u002Fp>\n        <\u002Farticle>\n\n        <article class=\"news-post\">\n          <h3 class=\"news-title\">Priser justert fra 1. mai<\u002Fh3>\n          <div class=\"news-date\">28. mars<\u002Fdiv>\n          <p class=\"news-body\">Årlig indeksregulering tilsvarer 2,8 % for 2026. Faktura i mai viser ny sats. Kontakt oss ved spørsmål.<\u002Fp>\n        <\u002Farticle>\n      <\u002Fdiv>\n\n      <!-- REPORT SCREEN -->\n      <div class=\"screen\" id=\"screen-report\">\n        <button class=\"back-btn\" onclick=\"goTo('home')\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M19 12H5M12 19l-7-7 7-7\"><\u002Fpath><\u002Fsvg>\n          Tilbake\n        <\u002Fbutton>\n\n        <span class=\"eyebrow\">Meld inn<\u002Fspan>\n        <h1 class=\"screen-title\">Hva gjelder<br><em>det?<\u002Fem><\u002Fh1>\n\n        <div class=\"input-group\">\n          <label>Kategori<\u002Flabel>\n          <div class=\"chips-row\">\n            <div class=\"chip active\" onclick=\"toggleChip(this)\">Avvik<\u002Fdiv>\n            <div class=\"chip\" onclick=\"toggleChip(this)\">Tomt for<\u002Fdiv>\n            <div class=\"chip\" onclick=\"toggleChip(this)\">Ødelagt<\u002Fdiv>\n            <div class=\"chip\" onclick=\"toggleChip(this)\">Tapt og funnet<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n\n        <div class=\"input-group\">\n          <label>Hvor på bygget?<\u002Flabel>\n          <input type=\"text\" class=\"input-field\" value=\"2. etasje, møterom Fjord\" readonly=\"\">\n        <\u002Fdiv>\n\n        <div class=\"input-group\">\n          <label>Beskrivelse<\u002Flabel>\n          <textarea class=\"input-field\" placeholder=\"Beskriv kort hva det gjelder...\"><\u002Ftextarea>\n        <\u002Fdiv>\n\n        <div class=\"input-group\">\n          <label>Bilde (valgfritt men anbefalt)<\u002Flabel>\n          <div class=\"photo-upload\" onclick=\"showToast('Kamera åpnes')\">\n            <div class=\"icon\">\n              <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z\"><\u002Fpath><circle cx=\"12\" cy=\"13\" r=\