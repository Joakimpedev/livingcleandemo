16;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"2c2b9ed3-b940-4f16-8458-34825eecd9aa\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"f1d1179a-dfeb-4ff1-95ef-4d0e024c43e9\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"8767330b-9767-4145-829a-70021ab3f968\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* cyrillic */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"184c734e-ea24-46de-9a1e-c5a3aa40a0f3\") format('woff2');\n  unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"2c2b9ed3-b940-4f16-8458-34825eecd9aa\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"f1d1179a-dfeb-4ff1-95ef-4d0e024c43e9\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"8767330b-9767-4145-829a-70021ab3f968\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* cyrillic */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"184c734e-ea24-46de-9a1e-c5a3aa40a0f3\") format('woff2');\n  unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"2c2b9ed3-b940-4f16-8458-34825eecd9aa\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"f1d1179a-dfeb-4ff1-95ef-4d0e024c43e9\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Playfair Display';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"8767330b-9767-4145-829a-70021ab3f968\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }\n\n  :root {\n    --bg: #F4EFE6;\n    --bg-card: #FFFFFF;\n    --ink: #1F2A24;\n    --ink-soft: #4A554E;\n    --ink-muted: #8A9089;\n    --line: #E5DFD3;\n    --accent: #1F3D2F;\n    --accent-soft: #D5DDD3;\n    --warn: #A34E1C;\n    --warn-soft: #F2E0D0;\n    --success: #1F3D2F;\n  }\n\n  html, body {\n    background: #1A1D1A;\n    font-family: 'Inter', sans-serif;\n    color: var(--ink);\n    min-height: 100vh;\n    overflow-x: hidden;\n  }\n\n  body {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 24px 16px;\n    background:\n      radial-gradient(ellipse at 20% 10%, rgba(45,74,62,0.15) 0%, transparent 50%),\n      radial-gradient(ellipse at 80% 90%, rgba(180,84,31,0.08) 0%, transparent 50%),\n      #1A1D1A;\n  }\n\n  .device-wrapper {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 20px;\n  }\n\n  .device-label {\n    font-family: 'Playfair Display', serif;\n    font-style: italic;\n    font-weight: 300;\n    font-size: 14px;\n    color: rgba(245,242,237,0.5);\n    letter-spacing: 0.02em;\n  }\n\n  .phone {\n    width: 390px;\n    max-width: 100%;\n    height: 780px;\n    background: var(--bg);\n    border-radius: 44px;\n    overflow: hidden;\n    position: relative;\n    box-shadow:\n      0 0 0 10px #0a0a0a,\n      0 0 0 11px #2a2a2a,\n      0 30px 80px rgba(0,0,0,0.6),\n      0 10px 30px rgba(0,0,0,0.4);\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* Status bar */\n  .status-bar {\n    height: 44px;\n    padding: 0 32px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    font-size: 15px;\n    font-weight: 600;\n    color: var(--ink);\n    flex-shrink: 0;\n    padding-top: 8px;\n  }\n\n  .status-icons { display: flex; gap: 5px; align-items: center; }\n  .status-icons svg { width: 16px; height: 11px; }\n\n  /* Notch */\n  .notch {\n    position: absolute;\n    top: 8px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 110px;\n    height: 32px;\n    background: #0a0a0a;\n    border-radius: 20px;\n    z-index: 10;\n  }\n\n  /* App content area */\n  .app-content {\n    flex: 1;\n    overflow-y: auto;\n    overflow-x: hidden;\n    scroll-behavior: smooth;\n    -webkit-overflow-scrolling: touch;\n  }\n  .app-content::-webkit-scrollbar { display: none; }\n\n  /* Screen */\n  .screen {\n    display: none;\n    padding: 8px 24px 100px;\n    animation: fadeIn 0.3s ease;\n  }\n  .screen.active { display: block; }\n\n  @keyframes fadeIn {\n    from { opacity: 0; transform: translateY(4px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  /* Typography */\n  .eyebrow {\n    font-family: 'Inter', sans-serif;\n    font-size: 11px;\n    font-weight: 500;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--ink-muted);\n  }\n\n  h1.screen-title {\n    font-family: 'Playfair Display', serif;\n    font-weight: 400;\n    font-size: 38px;\n    line-height: 1;\n    letter-spacing: -0.02em;\n    color: var(--ink);\n    margin-top: 8px;\n    margin-bottom: 24px;\n  }\n  h1.screen-title em {\n    font-style: italic;\n    font-weight: 300;\n  }\n\n  h2.section-title {\n    font-family: 'Playfair Display', serif;\n    font-weight: 400;\n    font-size: 22px;\n    letter-spacing: -0.01em;\n    margin-bottom: 14px;\n  }\n\n  /* HOME SCREEN */\n  .greeting-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    margin-top: 16px;\n    margin-bottom: 4px;\n  }\n\n  .avatar {\n    width: 42px;\n    height: 42px;\n    border-radius: 50%;\n    background: var(--accent);\n    color: #F5F2ED;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 16px;\n    font-weight: 400;\n  }\n\n  .hero-card {\n    background: var(--ink);\n    color: var(--bg);\n    border-radius: 24px;\n    padding: 24px;\n    margin-bottom: 20px;\n    position: relative;\n    overflow: hidden;\n  }\n  .hero-card::before {\n    content: '';\n    position: absolute;\n    top: -40px;\n    right: -40px;\n    width: 180px;\n    height: 180px;\n    background: radial-gradient(circle, rgba(217,225,220,0.08) 0%, transparent 70%);\n  }\n\n  .hero-status {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    padding: 4px 10px;\n    background: rgba(217,225,220,0.12);\n    border-radius: 100px;\n    font-size: 11px;\n    font-weight: 500;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: var(--accent-soft);\n  }\n  .hero-status .dot {\n    width: 6px;\n    height: 6px;\n    background: #7FB98A;\n    border-radius: 50%;\n    animation: pulse 2s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.4; }\n  }\n\n  .hero-headline {\n    font-family: 'Playfair Display', serif;\n    font-weight: 300;\n    font-size: 28px;\n    line-height: 1.1;\n    letter-spacing: -0.01em;\n    margin-top: 14px;\n    margin-bottom: 14px;\n  }\n  .hero-headline strong { font-weight: 500; }\n\n  .hero-meta {\n    display: flex;\n    gap: 20px;\n    margin-top: 20px;\n    padding-top: 16px;\n    border-top: 1px solid rgba(245,242,237,0.1);\n  }\n  .hero-meta-item .label {\n    font-size: 10px;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: rgba(245,242,237,0.5);\n    margin-bottom: 3px;\n  }\n  .hero-meta-item .value {\n    font-family: 'Playfair Display', serif;\n    font-size: 16px;\n    font-weight: 400;\n  }\n\n  .hero-sub {\n    font-size: 13px;\n    line-height: 1.55;\n    color: rgba(244,239,230,0.75);\n    margin-top: 4px;\n    position: relative;\n  }\n\n  /* Hurtighandlinger — editorial liste */\n  .quick-list {\n    margin: 4px 0 24px;\n    border-top: 1px solid var(--line);\n  }\n\n  .quick-row {\n    display: flex;\n    align-items: center;\n    gap: 18px;\n    padding: 18px 4px;\n    border-bottom: 1px solid var(--line);\n    cursor: pointer;\n    transition: padding 0.2s ease;\n  }\n  .quick-row:active { background: rgba(31,61,47,0.03); }\n\n  .quick-row .row-icon {\n    color: var(--ink-soft);\n    flex-shrink: 0;\n    transition: color 0.2s ease;\n  }\n  .quick-row.warn .row-icon { color: var(--warn); }\n\n  .quick-row .row-text {\n    flex: 1;\n    min-width: 0;\n  }\n  .quick-row .row-label {\n    font-family: 'Playfair Display', serif;\n    font-size: 19px;\n    font-weight: 400;\n    color: var(--ink);\n    line-height: 1.15;\n    letter-spacing: -0.01em;\n    transition: color 0.2s ease;\n  }\n  .quick-row .row-sub {\n    font-size: 12px;\n    color: var(--ink-muted);\n    margin-top: 3px;\n    letter-spacing: 0.01em;\n  }\n\n  .quick-row .row-arrow {\n    color: var(--ink-muted);\n    flex-shrink: 0;\n    transition: transform 0.2s ease, color 0.2s ease;\n  }\n  .quick-row:hover .row-arrow,\n  .quick-row:active .row-arrow {\n    color: var(--accent);\n    transform: translateX(3px);\n  }\n  .quick-row:hover .row-label {\n    color: var(--accent);\n  }\n\n  /* Updates feed */\n  .update-card {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    padding: 16px;\n    margin-bottom: 10px;\n  }\n\n  .update-head {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 10px;\n  }\n\n  .update-brand {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .update-logo {\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n    background: var(--accent);\n    color: var(--bg);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 13px;\n    font-weight: 500;\n    letter-spacing: -0.02em;\n  }\n\n  .update-author {\n    font-size: 13px;\n    font-weight: 500;\n    color: var(--ink);\n    line-height: 1.1;\n  }\n  .update-time {\n    font-size: 11px;\n    color: var(--ink-muted);\n    margin-top: 2px;\n  }\n\n  .update-body {\n    font-size: 13px;\n    line-height: 1.55;\n    color: var(--ink-soft);\n    margin-bottom: 12px;\n  }\n\n  .update-actions {\n    display: flex;\n    gap: 8px;\n    padding-top: 10px;\n    border-top: 1px solid var(--line);\n  }\n\n  .like-btn {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    padding: 6px 12px;\n    background: none;\n    border: 1px solid var(--line);\n    border-radius: 100px;\n    color: var(--ink-soft);\n    font-family: inherit;\n    font-size: 12px;\n    cursor: pointer;\n    transition: all 0.15s ease;\n  }\n  .like-btn:active { transform: scale(0.94); }\n  .like-btn.liked {\n    background: var(--accent-soft);\n    border-color: var(--accent-soft);\n    color: var(--accent);\n  }\n  .like-btn.liked svg { fill: var(--accent); }\n\n  /* REPORT SCREEN */\n  .back-btn {\n    background: none;\n    border: none;\n    font-size: 14px;\n    color: var(--ink-soft);\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    padding: 8px 0;\n    cursor: pointer;\n    margin-top: 8px;\n    font-family: inherit;\n  }\n  .back-btn:active { opacity: 0.6; }\n\n  .input-group {\n    margin-bottom: 16px;\n  }\n  .input-group label {\n    display: block;\n    font-size: 12px;\n    font-weight: 500;\n    color: var(--ink-soft);\n    margin-bottom: 8px;\n    letter-spacing: 0.02em;\n  }\n  .input-field {\n    width: 100%;\n    padding: 14px 16px;\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    font-family: inherit;\n    font-size: 14px;\n    color: var(--ink);\n    outline: none;\n    transition: border-color 0.15s ease;\n  }\n  .input-field:focus {\n    border-color: var(--accent);\n  }\n  textarea.input-field {\n    resize: none;\n    min-height: 90px;\n    line-height: 1.5;\n  }\n\n  .photo-upload {\n    background: var(--bg-card);\n    border: 1.5px dashed var(--line);\n    border-radius: 14px;\n    padding: 28px;\n    text-align: center;\n    cursor: pointer;\n    transition: border-color 0.15s ease, background 0.15s ease;\n  }\n  .photo-upload:hover {\n    border-color: var(--accent);\n    background: var(--accent-soft);\n  }\n  .photo-upload .icon {\n    color: var(--ink-muted);\n    margin-bottom: 8px;\n  }\n  .photo-upload .label {\n    font-size: 13px;\n    color: var(--ink-soft);\n    font-weight: 500;\n  }\n  .photo-upload .hint {\n    font-size: 11px;\n    color: var(--ink-muted);\n    margin-top: 2px;\n  }\n\n  .chips-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n  .chip {\n    padding: 8px 14px;\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 100px;\n    font-size: 13px;\n    color: var(--ink-soft);\n    cursor: pointer;\n    transition: all 0.15s ease;\n  }\n  .chip.active {\n    background: var(--ink);\n    color: var(--bg);\n    border-color: var(--ink);\n  }\n\n  .primary-btn {\n    width: 100%;\n    padding: 16px;\n    background: var(--ink);\n    color: var(--bg);\n    border: none;\n    border-radius: 14px;\n    font-family: inherit;\n    font-size: 15px;\n    font-weight: 500;\n    cursor: pointer;\n    margin-top: 20px;\n    letter-spacing: 0.01em;\n    transition: transform 0.15s ease;\n  }\n  .primary-btn:active {\n    transform: scale(0.98);\n  }\n\n  /* BOOK SCREEN */\n  .service-card {\n    background: var(--bg-card);\n    border-radius: 18px;\n    padding: 18px;\n    border: 1px solid var(--line);\n    margin-bottom: 10px;\n    display: flex;\n    gap: 14px;\n    align-items: center;\n    cursor: pointer;\n    transition: border-color 0.15s ease;\n  }\n  .service-card:active {\n    border-color: var(--accent);\n  }\n\n  .service-icon {\n    width: 44px;\n    height: 44px;\n    background: var(--accent-soft);\n    border-radius: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--accent);\n    flex-shrink: 0;\n  }\n\n  .service-info {\n    flex: 1;\n  }\n  .service-info .name {\n    font-family: 'Playfair Display', serif;\n    font-size: 17px;\n    color: var(--ink);\n    margin-bottom: 2px;\n  }\n  .service-info .desc {\n    font-size: 12px;\n    color: var(--ink-muted);\n  }\n  .service-price {\n    font-family: 'Playfair Display', serif;\n    font-size: 15px;\n    color: var(--ink-soft);\n  }\n  .service-price small {\n    font-size: 10px;\n    color: var(--ink-muted);\n    display: block;\n    text-align: right;\n    margin-top: 2px;\n  }\n\n  /* ACTIVITY SCREEN */\n  .log-group {\n    margin-bottom: 24px;\n  }\n  .log-date {\n    font-family: 'Playfair Display', serif;\n    font-style: italic;\n    font-weight: 300;\n    font-size: 14px;\n    color: var(--ink-muted);\n    margin-bottom: 10px;\n    padding-left: 4px;\n  }\n\n  .log-entry {\n    background: var(--bg-card);\n    border-radius: 16px;\n    padding: 16px;\n    border: 1px solid var(--line);\n    margin-bottom: 8px;\n  }\n  .log-top {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    margin-bottom: 10px;\n  }\n  .log-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 16px;\n    color: var(--ink);\n  }\n  .log-time {\n    font-size: 11px;\n    color: var(--ink-muted);\n    font-variant-numeric: tabular-nums;\n  }\n  .log-staff {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 10px;\n  }\n  .log-staff-avatar {\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    background: var(--accent-soft);\n    color: var(--accent);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 10px;\n    font-weight: 600;\n  }\n  .log-staff .name {\n    font-size: 12px;\n    color: var(--ink-soft);\n  }\n  .log-tasks {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    margin-top: 10px;\n    padding-top: 10px;\n    border-top: 1px solid var(--line);\n  }\n  .log-task {\n    font-size: 11px;\n    color: var(--ink-soft);\n    padding: 3px 8px;\n    background: var(--bg);\n    border-radius: 100px;\n  }\n  .log-task::before {\n    content: '✓';\n    margin-right: 4px;\n    color: var(--success);\n  }\n\n  /* CHAT */\n  .chat-contact {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 14px;\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 16px;\n    margin-bottom: 20px;\n  }\n\n  .chat-thread {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n\n  .chat-msg {\n    display: flex;\n    flex-direction: column;\n    max-width: 82%;\n  }\n  .chat-msg.them { align-self: flex-start; }\n  .chat-msg.you { align-self: flex-end; align-items: flex-end; }\n\n  .chat-msg .bubble {\n    padding: 12px 16px;\n    border-radius: 18px;\n    font-size: 14px;\n    line-height: 1.45;\n  }\n  .chat-msg.them .bubble {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    color: var(--ink);\n    border-bottom-left-radius: 6px;\n  }\n  .chat-msg.you .bubble {\n    background: var(--ink);\n    color: var(--bg);\n    border-bottom-right-radius: 6px;\n  }\n\n  .chat-msg .meta {\n    font-size: 10px;\n    color: var(--ink-muted);\n    margin-top: 4px;\n    letter-spacing: 0.03em;\n  }\n\n  .chat-input-row {\n    display: flex;\n    gap: 8px;\n    align-items: center;\n  }\n  .chat-input-row .input-field { flex: 1; }\n\n  .chat-send {\n    width: 48px;\n    height: 48px;\n    border-radius: 14px;\n    background: var(--ink);\n    color: var(--bg);\n    border: none;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    flex-shrink: 0;\n    transition: transform 0.15s ease;\n  }\n  .chat-send:active { transform: scale(0.94); }\n\n  /* NYHETER / FEED */\n  .news-post {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    padding: 20px;\n    margin-bottom: 12px;\n  }\n  .news-post.pinned {\n    background: var(--ink);\n    color: var(--bg);\n    border-color: var(--ink);\n  }\n\n  .news-tag {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 500;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    padding: 3px 9px;\n    background: rgba(217,225,220,0.15);\n    color: var(--accent-soft);\n    border-radius: 100px;\n    margin-bottom: 10px;\n  }\n\n  .news-title {\n    font-family: 'Playfair Display', serif;\n    font-weight: 400;\n    font-size: 19px;\n    line-height: 1.2;\n    letter-spacing: -0.01em;\n    margin-bottom: 4px;\n  }\n  .news-post.pinned .news-title { color: var(--bg); }\n\n  .news-date {\n    font-size: 11px;\n    color: var(--ink-muted);\n    margin-bottom: 10px;\n    letter-spacing: 0.02em;\n  }\n  .news-post.pinned .news-date { color: rgba(245,242,237,0.55); }\n\n  .news-body {\n    font-size: 13px;\n    line-height: 1.55;\n    color: var(--ink-soft);\n  }\n  .news-post.pinned .news-body { color: rgba(245,242,237,0.82); }\n\n\n  /* PERM */\n  .doc-card {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 16px;\n    padding: 14px 16px;\n    margin-bottom: 8px;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    cursor: pointer;\n    transition: border-color 0.15s ease;\n  }\n  .doc-card:active { border-color: var(--accent); }\n\n  .doc-icon {\n    width: 40px;\n    height: 40px;\n    background: var(--accent-soft);\n    color: var(--accent);\n    border-radius: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .doc-info .doc-name {\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--ink);\n    margin-bottom: 2px;\n  }\n  .doc-info .doc-meta {\n    font-size: 11px;\n    color: var(--ink-muted);\n  }\n\n  /* GALLERI */\n  .gallery-item {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    padding: 16px;\n    margin-bottom: 12px;\n  }\n  .gallery-head {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    margin-bottom: 12px;\n  }\n  .gallery-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 16px;\n    color: var(--ink);\n  }\n  .gallery-date {\n    font-size: 11px;\n    color: var(--ink-muted);\n    margin-top: 2px;\n  }\n  .gallery-tag {\n    font-size: 10px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 3px 9px;\n    background: var(--accent-soft);\n    color: var(--accent);\n    border-radius: 100px;\n    font-weight: 500;\n  }\n\n  .gallery-pair {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 8px;\n  }\n  .gallery-pic {\n    aspect-ratio: 1 / 1;\n    border-radius: 12px;\n    overflow: hidden;\n    position: relative;\n  }\n  .pic-surface {\n    width: 100%;\n    height: 100%;\n  }\n  .pic-surface.dull {\n    background:\n      repeating-linear-gradient(90deg, #5a5a52 0, #5a5a52 30px, #4a4a42 30px, #4a4a42 60px);\n    filter: brightness(0.85);\n  }\n  .pic-surface.shiny {\n    background:\n      linear-gradient(115deg, rgba(255,255,255,0.4) 0%, transparent 40%),\n      repeating-linear-gradient(90deg, #7a7a70 0, #7a7a70 30px, #6a6a60 30px, #6a6a60 60px);\n  }\n  .pic-surface.carpet-dirty {\n    background:\n      radial-gradient(circle at 30% 40%, rgba(60,40,20,0.4) 0%, transparent 25%),\n      radial-gradient(circle at 70% 60%, rgba(80,50,30,0.3) 0%, transparent 20%),\n      #7a6a58;\n  }\n  .pic-surface.carpet-clean {\n    background: #a89a85;\n  }\n  .pic-surface.window-dirty {\n    background:\n      radial-gradient(circle at 40% 30%, rgba(150,140,120,0.5) 0%, transparent 30%),\n      radial-gradient(circle at 70% 70%, rgba(150,140,120,0.4) 0%, transparent 25%),\n      linear-gradient(180deg, #87a5b8 0%, #6b8ba0 100%);\n  }\n  .pic-surface.window-clean {\n    background: linear-gradient(180deg, #a8c5d8 0%, #87a5b8 100%);\n  }\n  .pic-label {\n    position: absolute;\n    top: 8px;\n    left: 8px;\n    padding: 3px 8px;\n    background: rgba(26,29,26,0.85);\n    color: #F5F2ED;\n    font-size: 10px;\n    font-weight: 500;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    border-radius: 100px;\n  }\n\n  /* MIN SIDE / PROFILE */\n  .profile-summary {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    padding: 6px 18px;\n  }\n  .profile-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 14px 0;\n    border-bottom: 1px solid var(--line);\n    gap: 16px;\n  }\n  .profile-row:last-child { border-bottom: none; }\n  .profile-key {\n    font-size: 12px;\n    color: var(--ink-muted);\n    letter-spacing: 0.03em;\n  }\n  .profile-val {\n    font-size: 13px;\n    color: var(--ink);\n    font-weight: 500;\n    text-align: right;\n  }\n\n  .user-row {\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 12px 14px;\n    margin-bottom: 8px;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .user-avatar {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    background: var(--accent-soft);\n    color: var(--accent);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 13px;\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .user-info { flex: 1; }\n  .user-name {\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--ink);\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .user-badge {\n    font-size: 9px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 2px 7px;\n    background: var(--accent);\n    color: var(--bg);\n    border-radius: 100px;\n    font-weight: 500;\n  }\n  .user-role {\n    font-size: 11px;\n    color: var(--ink-muted);\n    margin-top: 2px;\n  }\n\n  .invite-card {\n    background: var(--accent-soft);\n    border-radius: 16px;\n    padding: 16px;\n    margin-top: 12px;\n    display: flex;\n    gap: 14px;\n    align-items: flex-start;\n  }\n  .invite-icon {\n    width: 40px;\n    height: 40px;\n    background: var(--accent);\n    color: var(--bg);\n    border-radius: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .invite-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 16px;\n    color: var(--ink);\n    margin-bottom: 3px;\n  }\n  .invite-sub {\n    font-size: 12px;\n    color: var(--ink-soft);\n    line-height: 1.45;\n  }\n\n  .settings-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 16px 18px;\n    background: var(--bg-card);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    margin-bottom: 6px;\n    cursor: pointer;\n    transition: border-color 0.15s ease;\n  }\n  .settings-row:active { border-color: var(--accent); }\n  .settings-row.logout .settings-label { color: var(--warn); }\n  .settings-row.logout svg { color: var(--warn); }\n  .settings-label {\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--ink);\n  }\n\n  /* Avatar som knapp */\n  .avatar {\n    cursor: pointer;\n    transition: transform 0.15s ease;\n  }\n  .avatar:active { transform: scale(0.94); }\n\n  /* Bottom navigation */\n  .tab-bar {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    height: 84px;\n    background: rgba(245,242,237,0.85);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border-top: 1px solid var(--line);\n    display: flex;\n    justify-content: space-around;\n    padding: 8px 16px 24px;\n    z-index: 5;\n  }\n\n  .tab {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 4px;\n    background: none;\n    border: none;\n    cursor: pointer;\n    padding: 6px 0;\n    font-family: inherit;\n    color: var(--ink-muted);\n    transition: color 0.15s ease;\n  }\n  .tab.active { color: var(--ink); }\n  .tab svg { width: 22px; height: 22px; stroke-width: 1.5; }\n  .tab .tab-label {\n    font-size: 10px;\n    letter-spacing: 0.04em;\n    font-weight: 500;\n  }\n\n  /* Home indicator */\n  .home-indicator {\n    position: absolute;\n    bottom: 8px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 134px;\n    height: 5px;\n    background: var(--ink);\n    border-radius: 100px;\n    opacity: 0.3;\n    z-index: 6;\n  }\n\n  /* Success toast */\n  .toast {\n    position: absolute;\n    bottom: 110px;\n    left: 50%;\n    transform: translateX(-50%) translateY(20px);\n    background: var(--ink);\n    color: var(--bg);\n    padding: 12px 20px;\n    border-radius: 100px;\n    font-size: 13px;\n    opacity: 0;\n    transition: opacity 0.3s ease, transform 0.3s ease;\n    z-index: 20;\n    white-space: nowrap;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.3);\n  }\n  .toast.show {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n\n  .logo-brand {\n    font-family: 'Playfair Display', serif;\n    font-weight: 500;\n    letter-spacing: -0.02em;\n    font-size: 18px;\n    color: var(--ink);\n  }\n  .logo-brand em {\n    font-style: italic;\n    font-weight: 300;\n    color: var(--accent);\n  }\n\n  @media (max-width: 440px) {\n    body { padding: 12px 0; }\n    .phone {\n      border-radius: 0;\n      box-shadow: none;\n      height: 100vh;\n      max-height: none;\n    }\n    .device-label { display: none; }\n  }\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n\n<div class=\"device-wrapper\">\n  <div class=\"device-label\">Kundeapp — <em>Living Clean<\u002Fem><\u002Fdiv>\n\n  <div class=\"phone\">\n    <di